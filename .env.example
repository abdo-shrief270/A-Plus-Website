# --- Public site ---
# Used for OG image generation and absolute URLs in the sitemap.
NUXT_PUBLIC_SITE_URL=https://aplus.test

# --- Backend API ---
# Base URL for all REST calls. The trailing /api segment is required because
# every service path (e.g. /v2/auth/login) is appended to this value.
NUXT_PUBLIC_API_BASE_URL=https://control.apls-edu.com/api
